VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

VITE_GIPHY_API_KEY=your_giphy_api_key

# App Check bot protection (reCAPTCHA v3). Get the site key from
# Firebase Console -> App Check -> register web app with reCAPTCHA v3.
# Public key, safe in the client bundle. App Check is skipped if this is unset.
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
