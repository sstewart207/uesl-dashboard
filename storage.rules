rules_version = '2';

// Cloud Storage security rules for UESL Dashboard.
// Only managed asset today is user avatars, written by uploadAvatar()
// at path: avatars/{uid}/{timestamp}-{filename}  (see src/firebase/firestore.js).
service firebase.storage {
  match /b/{bucket}/o {

    // AVATARS — a user may write ONLY their own folder; any signed-in user may read
    // (avatars are shown across the member directory/profiles). Uploads are limited to
    // images under 5 MB so nobody can dump arbitrary/huge files in their folder.
    match /avatars/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Everything else is denied by default (fail closed).
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
