rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin()    { return isSignedIn() && request.auth.token.email == 'sstewart207@gmail.com'; }
    function myDoc()      { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isApproved() { return isSignedIn() && (isAdmin() || myDoc().approved == true); }
    function isCoach()    { return isSignedIn() && (isAdmin() || myDoc().role == 'coach' || myDoc().role == 'admin'); }

    // USERS — read own (admins/coaches read all); create own w/ safe defaults;
    // admins/coaches manage approvals & roles; users edit own profile but can't
    // change their own approved flag or role (no self-promotion).
    match /users/{uid} {
      // Own doc readable even while pending (login/profile fetch); any
      // approved member can read all users (member directory, profiles,
      // @mention matching, RSVP rosters).
      allow read: if isSignedIn() && (request.auth.uid == uid || isApproved());
      allow create: if isAdmin() ||
        (request.auth.uid == uid
         && request.resource.data.approved == false
         && request.resource.data.role == 'pending');
      // Only admin can delete user docs.
      allow delete: if isAdmin();
      // Admin = full power. A coach may manage approvals: toggle `approved` and
      // set role to student/coach/pending (approve + revoke) — but NEVER mint an
      // admin, touch an existing admin's doc, or edit their own doc via this branch.
      // A member may edit their own profile but can't change approved/role (no self-promotion).
      allow update: if isAdmin()
        || (isCoach()
            && request.auth.uid != uid
            && resource.data.role != 'admin'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approved', 'role'])
            && request.resource.data.role in ['student', 'coach', 'pending'])
        || (request.auth.uid == uid
            && request.resource.data.approved == resource.data.approved
            && request.resource.data.role == resource.data.role);
    }

    // POSTS (+ comments): approved members read/create; update open (likes &
    // comment counts come from non-authors); delete restricted to author/coach.
    match /posts/{postId} {
      allow read: if isApproved();
      // Pin authorship on create so a member can't forge a post as someone else.
      allow create: if isApproved() && request.resource.data.authorUid == request.auth.uid;
      // Author/coach can edit anything; anyone else (approved) may ONLY change
      // like/comment-count fields — not the title/body. Blocks content tampering.
      allow update: if isApproved() && (
        resource.data.authorUid == request.auth.uid || isCoach()
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['likedBy', 'likeCount', 'commentCount'])
      );
      allow delete: if isApproved() && (resource.data.authorUid == request.auth.uid || isCoach());
      match /comments/{commentId} {
        allow read: if isApproved();
        // Pin authorship on create — no forging a comment as another member.
        allow create: if isApproved() && request.resource.data.authorUid == request.auth.uid;
        // Only the comment's author or a coach can edit/delete it.
        allow update, delete: if isApproved() && (resource.data.authorUid == request.auth.uid || isCoach());
      }
    }

    // EVENTS: read = approved; coaches create/delete; any approved member may
    // UPDATE so students can RSVP (rsvps map lives on the event doc).
    match /events/{id} {
      allow read: if isApproved();
      allow create, delete: if isCoach();
      // Coaches can edit the whole event; approved members may ONLY change
      // the rsvps map (so they can RSVP, not rewrite the event).
      allow update: if isCoach()
        || (isApproved() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rsvps']));
    }

    // BULLETINS: read = approved; write = coach/admin only.
    match /bulletins/{id} {
      allow read: if isApproved();
      allow write: if isCoach();
    }

    // TOURNAMENTS: coaches create/delete; approved members update (sign-ups).
    match /tournaments/{id} {
      allow read: if isApproved();
      allow create, delete: if isCoach();
      // Coaches edit the whole tournament; approved members may ONLY change
      // the participants list (so they can sign up, not rewrite it).
      allow update: if isCoach()
        || (isApproved() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants']));
    }

    // NOTIFICATIONS: anyone approved can send you one; only you read/mark-read.
    match /notifications/{uid}/items/{notifId} {
      allow read: if request.auth.uid == uid;
      allow create: if isApproved();
      allow update, delete: if request.auth.uid == uid;
    }
  }
}
